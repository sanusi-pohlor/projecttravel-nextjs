datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String
  province  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attraction {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  region      String
  latitude    Float
  longitude   Float
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}